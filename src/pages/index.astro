---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('./**/*.{md,mdx}');
const posts = allPosts
  .filter(p => p.frontmatter.pubDate)
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());

const musicPosts = posts.filter(p => p.frontmatter.section === 'music').slice(0, 3);
const filmPosts  = posts.filter(p => p.frontmatter.section === 'film').slice(0, 3);
const techPosts  = posts.filter(p => p.frontmatter.section === 'tech').slice(0, 3);
const notesPosts = posts.filter(p => p.frontmatter.section === 'notes').slice(0, 3);

const featured = posts[0];
const sidebar  = posts.slice(1, 3);

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('zh-TW', { month: 'short', day: 'numeric' });
}
---

<BaseLayout>
  <div class="container">

    <!-- HERO -->
    {featured && (
      <div class="hero-grid">
        <div class="hero-main">
          <div class="cover-img">{featured.frontmatter.emoji || '✨'}</div>
          <div class={`section-label ${featured.frontmatter.section || 'notes'}`}>
            {({'music':'音樂','film':'電影','tech':'科技','notes':'筆記'} as any)[featured.frontmatter.section] || '筆記'}
          </div>
          <h2><a href={featured.url}>{featured.frontmatter.title}</a></h2>
          <p class="excerpt">{featured.frontmatter.description}</p>
          <span style="font-family:var(--font-ui);font-size:0.75rem;color:var(--ink-light)">
            {fmtDate(featured.frontmatter.pubDate)}
          </span>
        </div>
        <div class="hero-sidebar">
          {sidebar.map(post => (
            <div class="sidebar-post">
              <div class="cover-sm">{post.frontmatter.emoji || '📄'}</div>
              <div class={`section-label ${post.frontmatter.section || 'notes'}`}>
                {({'music':'音樂','film':'電影','tech':'科技','notes':'筆記'} as any)[post.frontmatter.section] || '筆記'}
              </div>
              <h3><a href={post.url}>{post.frontmatter.title}</a></h3>
              <p style="font-family:var(--font-ui);font-size:0.75rem;color:var(--ink-light)">
                {fmtDate(post.frontmatter.pubDate)}
              </p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- MUSIC STRIP -->
    {musicPosts.length > 0 && (
      <div class="section-strip">
        <div class="section-strip-header">
          <span class="section-strip-title">🎵 音樂</span>
          <a href="/music" class="section-strip-more">更多 →</a>
        </div>
        <div class="strip-grid">
          {musicPosts.map(p => (
            <a href={p.url} class="strip-card">
              <div class="cover">{p.frontmatter.emoji || '🎵'}</div>
              <div class="section-label music">音樂</div>
              <h4>{p.frontmatter.title}</h4>
              <p class="meta">{fmtDate(p.frontmatter.pubDate)}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- FILM STRIP -->
    {filmPosts.length > 0 && (
      <div class="section-strip">
        <div class="section-strip-header">
          <span class="section-strip-title">🎬 電影</span>
          <a href="/film" class="section-strip-more">更多 →</a>
        </div>
        <div class="strip-grid">
          {filmPosts.map(p => (
            <a href={p.url} class="strip-card">
              <div class="cover">{p.frontmatter.emoji || '🎬'}</div>
              <div class="section-label film">電影</div>
              <h4>{p.frontmatter.title}</h4>
              <p class="meta">{fmtDate(p.frontmatter.pubDate)}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- TECH STRIP -->
    {techPosts.length > 0 && (
      <div class="section-strip">
        <div class="section-strip-header">
          <span class="section-strip-title">💻 科技</span>
          <a href="/tech" class="section-strip-more">更多 →</a>
        </div>
        <div class="strip-grid">
          {techPosts.map(p => (
            <a href={p.url} class="strip-card">
              <div class="cover">{p.frontmatter.emoji || '💻'}</div>
              <div class="section-label tech">科技</div>
              <h4>{p.frontmatter.title}</h4>
              <p class="meta">{fmtDate(p.frontmatter.pubDate)}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- NOTES STRIP -->
    {notesPosts.length > 0 && (
      <div class="section-strip">
        <div class="section-strip-header">
          <span class="section-strip-title">📝 筆記</span>
          <a href="/notes" class="section-strip-more">更多 →</a>
        </div>
        <div class="strip-grid">
          {notesPosts.map(p => (
            <a href={p.url} class="strip-card">
              <div class="cover">{p.frontmatter.emoji || '📝'}</div>
              <div class="section-label notes">筆記</div>
              <h4>{p.frontmatter.title}</h4>
              <p class="meta">{fmtDate(p.frontmatter.pubDate)}</p>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</BaseLayout>
